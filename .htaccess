# SGD — protecção de ficheiros sensíveis e pastas internas.

# Bloqueia acesso directo a ficheiros de configuração/dados/documentação.
<FilesMatch "\.(sql|env|md|ini|log)$">
    Require all denied
</FilesMatch>

# Força HTTPS em produção (certificado fornecido pelo hosting, ex: Let's Encrypt
# no Hostinger). Exclui localhost/127.0.0.1 para não quebrar o XAMPP local, que
# não tem certificado configurado.
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Nega acesso directo a includes/, app/ e scripts/ (só usados via
# include()/require() pelo PHP, nunca pedidos directos do browser).
RewriteRule ^(includes|app|scripts)/ - [F,L]

# Cabeçalhos de segurança básicos.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "same-origin"
</IfModule>
